---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Get in touch with AnglerSpecs.">
  <div class="panel-head">
    <div>
      <h1>Contact</h1>
      <p>Found a bug, a bad assumption, or have a calculator you'd want to see built?</p>
    </div>
  </div>
  <article class="guide">
    <p>Reach out at <a href="mailto:hello@anglerspecs.com" style="color:var(--sonar)">hello@anglerspecs.com</a>. Replace this with your real contact address before launch — AdSense review checks that this page resolves to something real.</p>
  </article>
</BaseLayout>
